## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.env

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]*/
bld/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
**/[Bb]in/*

# Visual Studio 2015/2017 cache/options directory
.vs/
Generated\ Files/

# Test and profiler files
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.VisualState.xml
*.sdf
*.pdb
*.aps
*.idb
*.VC.db
*.VC.VC.opendb
publish/
*.pubxml
*.publishproj
*.azurePubxml
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets
node_modules/
.vscode/
.idea/
.DS_Store
Thumbs.db

# Python / Tkinter specific ignores
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
.env
.envrc

# Data / logs
*.csv
*.log
# If you WANT to keep your session CSVs, uncomment the next line:
#!gazetrack_*.csv

# Build directories
build/
dist/

recordings/
*.avi
